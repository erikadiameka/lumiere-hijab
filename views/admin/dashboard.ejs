<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Lumière Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        blushBase: '#FCF9F9',
                        dustyPink: '#F2E8E9',
                        softMauve: '#E8DFE0',
                        darkPlum: '#4A3C3D',
                        roseWood: '#B89C9D'
                    },
                    fontFamily: {
                        serif: ['"Playfair Display"', 'serif'],
                        sans: ['"Poppins"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
</head>
<body class="font-sans bg-gray-50 text-darkPlum">

<div class="flex min-h-screen">
    <!-- SIDEBAR -->
    <aside class="w-64 bg-darkPlum text-white fixed h-full flex flex-col">
        <div class="p-8 border-b border-white/10">
            <h1 class="font-serif text-2xl text-roseWood">LUMIÈRE</h1>
            <p class="text-white/40 text-[10px] uppercase tracking-widest mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 p-4 mt-4">
            <ul class="space-y-1">
                <li>
                    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-roseWood/20 text-white font-medium text-sm">
                        📊 Dashboard
                    </a>
                </li>
                <li>
                    <a href="/admin/produk" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">
                        👗 Produk
                    </a>
                </li>
                <li>
                    <a href="/admin/pesanan" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">
                        📦 Pesanan
                    </a>
                </li>
                <li>
                    <a href="/admin/testimoni" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">
                        ⭐ Testimoni
                    </a>
                </li>
            </ul>
        </nav>
        <div class="p-4 border-t border-white/10">
            <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">
                🌐 Lihat Website
            </a>
            <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-red-500/20 text-white/70 hover:text-red-300 transition text-sm mt-1">
                🚪 Logout
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="ml-64 flex-1 p-8">
        <div class="mb-8">
            <h2 class="font-serif text-3xl text-darkPlum">Dashboard</h2>
            <p class="text-gray-400 text-sm mt-1">Selamat datang kembali, Admin!</p>
        </div>

        <!-- STATS -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-softMauve/50">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">Total Produk</p>
                <p class="font-serif text-4xl text-darkPlum"><%= totalProduk %></p>
                <a href="/admin/produk" class="text-roseWood text-xs mt-3 inline-block hover:underline">Kelola Produk →</a>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-softMauve/50">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">Total Pesanan</p>
                <p class="font-serif text-4xl text-darkPlum"><%= totalPesanan %></p>
                <a href="/admin/pesanan" class="text-roseWood text-xs mt-3 inline-block hover:underline">Lihat Pesanan →</a>
            </div>
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-softMauve/50">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">Pesanan Baru</p>
                <p class="font-serif text-4xl text-roseWood"><%= pesananBaru %></p>
                <a href="/admin/pesanan" class="text-roseWood text-xs mt-3 inline-block hover:underline">Proses Sekarang →</a>
            </div>
        </div>

        <!-- PESANAN TERBARU -->
        <div class="bg-white rounded-2xl shadow-sm border border-softMauve/50 overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-serif text-xl">Pesanan Terbaru</h3>
                <a href="/admin/pesanan" class="text-roseWood text-xs uppercase tracking-widest hover:underline">Lihat Semua</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-blushBase">
                        <tr>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-widest text-gray-400">Pembeli</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-widest text-gray-400">Total</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-widest text-gray-400">Pembayaran</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-widest text-gray-400">Status</th>
                            <th class="text-left px-6 py-4 text-[10px] uppercase tracking-widest text-gray-400">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        <% if (pesananTerbaru.length === 0) { %>
                        <tr>
                            <td colspan="5" class="text-center py-10 text-gray-400 italic">Belum ada pesanan</td>
                        </tr>
                        <% } %>
                        <% pesananTerbaru.forEach(p => { %>
                        <tr class="hover:bg-blushBase/50 transition">
                            <td class="px-6 py-4">
                                <p class="font-medium text-sm"><%= p.namaPembeli %></p>
                                <p class="text-xs text-gray-400"><%= p.email %></p>
                            </td>
                            <td class="px-6 py-4 text-sm font-medium text-roseWood">Rp <%= p.totalBayar.toLocaleString('id-ID') %></td>
                            <td class="px-6 py-4 text-xs text-gray-500"><%= p.metodePembayaran %></td>
                            <td class="px-6 py-4">
                                <% const statusColor = {
                                    'Menunggu Pembayaran': 'bg-yellow-100 text-yellow-700',
                                    'Pembayaran Dikonfirmasi': 'bg-blue-100 text-blue-700',
                                    'Diproses': 'bg-purple-100 text-purple-700',
                                    'Dikirim': 'bg-indigo-100 text-indigo-700',
                                    'Selesai': 'bg-green-100 text-green-700',
                                    'Dibatalkan': 'bg-red-100 text-red-700'
                                }[p.status] || 'bg-gray-100 text-gray-700' %>
                                <span class="px-3 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider <%= statusColor %>"><%= p.status %></span>
                            </td>
                            <td class="px-6 py-4">
                                <a href="/admin/pesanan/<%= p._id %>" class="text-roseWood text-xs hover:underline">Detail →</a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

</body>
</html>