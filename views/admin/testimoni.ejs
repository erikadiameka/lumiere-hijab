<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Testimoni - Lumière Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { blushBase: '#FCF9F9', dustyPink: '#F2E8E9', softMauve: '#E8DFE0', darkPlum: '#4A3C3D', roseWood: '#B89C9D' }, fontFamily: { serif: ['"Playfair Display"', 'serif'], sans: ['"Poppins"', 'sans-serif'] } } }
        }
    </script>
</head>
<body class="font-sans bg-gray-50 text-darkPlum">

<div class="flex min-h-screen">
    <aside class="w-64 bg-darkPlum text-white fixed h-full flex flex-col">
        <div class="p-8 border-b border-white/10">
            <h1 class="font-serif text-2xl text-roseWood">LUMIÈRE</h1>
            <p class="text-white/40 text-[10px] uppercase tracking-widest mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 p-4 mt-4">
            <ul class="space-y-1">
                <li><a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">📊 Dashboard</a></li>
                <li><a href="/admin/produk" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">👗 Produk</a></li>
                <li><a href="/admin/pesanan" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">📦 Pesanan</a></li>
                <li><a href="/admin/testimoni" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-roseWood/20 text-white font-medium text-sm">⭐ Testimoni</a></li>
            </ul>
        </nav>
        <div class="p-4 border-t border-white/10">
            <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 text-white/70 hover:text-white transition text-sm">🌐 Lihat Website</a>
            <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-red-500/20 text-white/70 hover:text-red-300 transition text-sm mt-1">🚪 Logout</a>
        </div>
    </aside>

    <main class="ml-64 flex-1 p-8">
        <div class="mb-8">
            <h2 class="font-serif text-3xl text-darkPlum">Kelola Testimoni</h2>
            <p class="text-gray-400 text-sm mt-1">Tambah & kelola ulasan pelanggan</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- FORM TAMBAH -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-softMauve/50">
                    <h3 class="font-medium mb-5 text-sm uppercase tracking-widest text-gray-400">Tambah Testimoni</h3>
                    <form action="/admin/testimoni/tambah" method="POST" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">Nama Pelanggan *</label>
                            <input type="text" name="namaPelanggan" required placeholder="Nama pelanggan"
                                class="w-full border border-softMauve rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-roseWood transition">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">Produk yang Dibeli</label>
                            <input type="text" name="produk" placeholder="Contoh: Pashmina Voile"
                                class="w-full border border-softMauve rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-roseWood transition">
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">Rating</label>
                            <select name="rating" class="w-full border border-softMauve rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-roseWood transition">
                                <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                                <option value="4">⭐⭐⭐⭐ (4)</option>
                                <option value="3">⭐⭐⭐ (3)</option>
                                <option value="2">⭐⭐ (2)</option>
                                <option value="1">⭐ (1)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">Pesan / Ulasan *</label>
                            <textarea name="pesan" rows="4" required placeholder="Tulis ulasan pelanggan..."
                                class="w-full border border-softMauve rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-roseWood transition"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-darkPlum text-white py-3 rounded-lg text-sm font-medium hover:bg-roseWood transition">
                            + Tambah Testimoni
                        </button>
                    </form>
                </div>
            </div>

            <!-- DAFTAR TESTIMONI -->
            <div class="lg:col-span-2 space-y-4">
                <% if (testimoni.length === 0) { %>
                <div class="bg-white rounded-2xl p-12 shadow-sm border border-softMauve/50 text-center">
                    <p class="text-gray-400 italic">Belum ada testimoni. Tambahkan dari form di sebelah kiri.</p>
                </div>
                <% } %>
                <% testimoni.forEach(t => { %>
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-softMauve/50">
                    <div class="flex justify-between items-start">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <p class="font-medium text-sm"><%= t.namaPelanggan %></p>
                                <span class="text-roseWood text-xs">
                                    <% for(let i=0; i<t.rating; i++) { %>★<% } %>
                                </span>
                                <span class="px-2 py-0.5 rounded-full text-[10px] <%= t.tampil ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                                    <%= t.tampil ? 'Tampil' : 'Disembunyikan' %>
                                </span>
                            </div>
                            <% if (t.produk) { %>
                            <p class="text-[10px] uppercase tracking-widest text-roseWood mb-2"><%= t.produk %></p>
                            <% } %>
                            <p class="text-sm text-gray-500 italic leading-relaxed">"<%= t.pesan %>"</p>
                            <p class="text-xs text-gray-300 mt-2"><%= new Date(t.createdAt).toLocaleDateString('id-ID') %></p>
                        </div>
                        <form action="/admin/testimoni/hapus/<%= t._id %>" method="POST" onsubmit="return confirm('Hapus testimoni ini?')" class="ml-4">
                            <button type="submit" class="text-red-400 text-xs hover:text-red-600 transition hover:underline">Hapus</button>
                        </form>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </main>
</div>

</body>
</html>