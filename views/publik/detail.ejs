<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= produk.nama %> - Lumière</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@0.321.0/font/lucide.min.css">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { blushBase: '#FCF9F9', dustyPink: '#F2E8E9', softMauve: '#E8DFE0', darkPlum: '#4A3C3D', roseWood: '#B89C9D' }, fontFamily: { serif: ['"Playfair Display"', 'serif'], sans: ['"Poppins"', 'sans-serif'] } } }
        }
    </script>
    <style>[x-cloak]{display:none!important} .glass-nav{background:rgba(252,249,249,0.85);backdrop-filter:blur(12px)}</style>
</head>
<body x-data="{ fotoAktif: '<%= produk.foto[0] || '' %>', mobileMenu: false }" class="font-sans bg-blushBase text-darkPlum antialiased">

    <!-- NAVBAR -->
    <nav class="fixed w-full z-[60] glass-nav border-b border-roseWood/10">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
            <div class="flex justify-between items-center h-20">
                <button @click="mobileMenu = !mobileMenu" class="text-darkPlum lg:hidden"><i class="lucide-menu"></i></button>
                <a href="/" class="font-serif text-2xl font-semibold tracking-tighter text-darkPlum">LUMIÈRE</a>
                <div class="hidden lg:flex space-x-10">
                    <a href="/katalog" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">Shop All</a>
                    <a href="/tentang" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">Our Story</a>
                    <a href="/kontak" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">Kontak</a>
                </div>
                <a href="/keranjang" class="hover:text-roseWood transition"><i class="lucide-shopping-bag w-5 h-5"></i></a>
            </div>
        </div>
    </nav>

    <div class="pt-20 max-w-7xl mx-auto px-6 py-12">
        <!-- BREADCRUMB -->
        <div class="flex items-center gap-2 text-xs text-gray-400 mb-10">
            <a href="/" class="hover:text-roseWood transition">Beranda</a>
            <span>/</span>
            <a href="/katalog" class="hover:text-roseWood transition">Katalog</a>
            <span>/</span>
            <span class="text-darkPlum"><%= produk.nama %></span>
        </div>

        <!-- DETAIL -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <!-- FOTO -->
            <div>
                <div class="aspect-square bg-dustyPink overflow-hidden mb-4">
                    <% if (produk.foto && produk.foto[0]) { %>
                    <img :src="fotoAktif" alt="<%= produk.nama %>" class="w-full h-full object-cover transition duration-500">
                    <% } else { %>
                    <div class="w-full h-full flex items-center justify-center font-serif text-2xl text-roseWood/40 italic"><%= produk.nama %></div>
                    <% } %>
                </div>
                <% if (produk.foto && produk.foto.length > 1) { %>
                <div class="flex gap-3">
                    <% produk.foto.forEach(f => { %>
                    <img src="<%= f %>" @click="fotoAktif='<%= f %>'"
                        class="w-20 h-20 object-cover cursor-pointer border-2 hover:border-roseWood transition"
                        :class="fotoAktif === '<%= f %>' ? 'border-roseWood' : 'border-transparent'">
                    <% }) %>
                </div>
                <% } %>
            </div>

            <!-- INFO -->
            <div class="flex flex-col justify-center">
                <span class="text-[10px] uppercase tracking-[0.3em] text-roseWood font-semibold mb-3"><%= produk.kategori %></span>
                <h1 class="font-serif text-4xl text-darkPlum mb-4"><%= produk.nama %></h1>

                <div class="mb-6">
                    <% if (produk.hargaDiskon > 0) { %>
                    <p class="text-gray-400 line-through text-sm">Rp <%= produk.harga.toLocaleString('id-ID') %></p>
                    <p class="font-serif text-3xl text-roseWood">Rp <%= produk.hargaDiskon.toLocaleString('id-ID') %></p>
                    <% } else { %>
                    <p class="font-serif text-3xl text-roseWood">Rp <%= produk.harga.toLocaleString('id-ID') %></p>
                    <% } %>
                </div>

                <p class="text-gray-500 leading-relaxed mb-6 font-light"><%= produk.deskripsi %></p>

                <p class="text-sm mb-6 <%= produk.stok > 0 ? 'text-green-600' : 'text-red-500' %>">
                    <%= produk.stok > 0 ? `✓ Stok tersedia (${produk.stok} pcs)` : '✗ Stok habis' %>
                </p>

                <% if (produk.stok > 0) { %>
                <form action="/keranjang/tambah" method="POST" class="space-y-4">
                    <input type="hidden" name="produkId" value="<%= produk._id %>">

                    <% if (produk.warna && produk.warna.length > 0) { %>
                    <div>
                        <p class="text-[11px] uppercase tracking-widest font-semibold mb-3">Pilih Warna</p>
                        <div class="flex flex-wrap gap-2">
                            <% produk.warna.forEach((w, i) => { %>
                            <label class="cursor-pointer">
                                <input type="radio" name="warna" value="<%= w %>" class="hidden peer" <%= i===0?'checked':'' %>>
                                <span class="px-4 py-2 border border-softMauve text-sm peer-checked:border-darkPlum peer-checked:bg-darkPlum peer-checked:text-white transition block">
                                    <%= w %>
                                </span>
                            </label>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>

                    <div>
                        <p class="text-[11px] uppercase tracking-widest font-semibold mb-3">Jumlah</p>
                        <input type="number" name="jumlah" value="1" min="1" max="<%= produk.stok %>"
                            class="w-24 border border-softMauve px-4 py-2 text-sm text-center focus:outline-none focus:border-roseWood transition">
                    </div>

                    <button type="submit" class="w-full bg-darkPlum text-white py-4 uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-roseWood transition-all duration-500 mt-4">
                        Tambah ke Keranjang
                    </button>
                </form>
                <% } %>

                <% if (produk.detail) { %>
                <div class="mt-8 pt-8 border-t border-softMauve">
                    <p class="text-[11px] uppercase tracking-widest font-semibold mb-3">Detail Produk</p>
                    <p class="text-gray-500 leading-relaxed font-light text-sm"><%= produk.detail %></p>
                </div>
                <% } %>
            </div>
        </div>

        <!-- PRODUK LAIN -->
        <% if (produkLain.length > 0) { %>
        <div class="mt-24">
            <div class="flex justify-between items-end mb-10">
                <h2 class="font-serif text-3xl text-darkPlum">Produk Lainnya</h2>
                <a href="/katalog" class="text-[11px] uppercase tracking-widest border-b border-roseWood pb-1 text-roseWood hover:text-darkPlum hover:border-darkPlum transition">Lihat Semua</a>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
                <% produkLain.forEach(p => { %>
                <div class="group">
                    <a href="/produk/<%= p._id %>">
                        <div class="aspect-[3/4] bg-dustyPink mb-4 overflow-hidden relative">
                            <% if (p.foto && p.foto[0]) { %>
                            <img src="<%= p.foto[0] %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
                            <% } else { %>
                            <div class="absolute inset-0 flex items-center justify-center text-roseWood/40 font-serif italic"><%= p.nama %></div>
                            <% } %>
                        </div>
                    </a>
                    <h3 class="text-sm font-medium group-hover:text-roseWood transition"><%= p.nama %></h3>
                    <p class="text-roseWood text-sm mt-1">Rp <%= p.harga.toLocaleString('id-ID') %></p>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>
    </div>

    <!-- FOOTER -->
    <footer class="bg-darkPlum text-blushBase pt-16 pb-8 mt-24">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <h1 class="font-serif text-3xl mb-4 tracking-tighter">LUMIÈRE</h1>
            <div class="flex justify-center gap-8 text-sm text-softMauve/70 mb-8">
                <a href="/katalog" class="hover:text-white transition">Katalog</a>
                <a href="/tentang" class="hover:text-white transition">Tentang</a>
                <a href="/kontak" class="hover:text-white transition">Kontak</a>
            </div>
            <p class="text-[10px] uppercase tracking-widest text-softMauve/40">&copy; 2025 Lumière Hijab Indonesia</p>
        </div>
    </footer>

</body>
</html>