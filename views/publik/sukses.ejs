<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pesanan Berhasil - Lumière</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { blushBase: '#FCF9F9', dustyPink: '#F2E8E9', softMauve: '#E8DFE0', darkPlum: '#4A3C3D', roseWood: '#B89C9D' }, fontFamily: { serif: ['"Playfair Display"', 'serif'], sans: ['"Poppins"', 'sans-serif'] } } }
        }
    </script>
</head>
<body class="font-sans bg-blushBase text-darkPlum antialiased min-h-screen flex flex-col items-center justify-center px-6">

    <div class="text-center max-w-lg w-full">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">✓</span>
        </div>
        <h1 class="font-serif text-4xl text-darkPlum mb-3">Pesanan Berhasil!</h1>
        <p class="text-gray-400 font-light mb-10">Terima kasih, <strong class="text-darkPlum"><%= order.namaPembeli %></strong>. Pesananmu sudah kami terima.</p>

        <div class="bg-white p-8 border border-softMauve text-left mb-8">
            <h3 class="font-serif text-lg mb-5">Ringkasan Pesanan</h3>
            <% order.items.forEach(item => { %>
            <div class="flex justify-between text-sm mb-3 text-gray-500">
                <span><%= item.namaProduk %> (<%= item.warna %>) x<%= item.jumlah %></span>
                <span>Rp <%= item.subtotal.toLocaleString('id-ID') %></span>
            </div>
            <% }) %>
            <div class="border-t border-softMauve pt-4 mt-4 space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-400">Ongkos Kirim</span>
                    <span>Rp <%= order.ongkir.toLocaleString('id-ID') %></span>
                </div>
                <div class="flex justify-between font-medium text-base">
                    <span>Total Bayar</span>
                    <span class="text-roseWood font-serif text-lg">Rp <%= order.totalBayar.toLocaleString('id-ID') %></span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Metode Pembayaran</span>
                    <span><%= order.metodePembayaran %></span>
                </div>
            </div>

            <% if (order.metodePembayaran !== 'COD') { %>
            <div class="mt-6 p-4 bg-dustyPink/50 text-sm">
                <p class="font-semibold mb-2">Info Transfer:</p>
                <p class="text-gray-500">BCA: <strong class="text-darkPlum">1234567890</strong> a.n Lumière Store</p>
                <p class="text-gray-400 text-xs mt-2">Konfirmasi via WhatsApp: <a href="https://wa.me/6281234567890" class="text-roseWood hover:underline">0812-3456-7890</a></p>
            </div>
            <% } %>
        </div>

        <div class="flex gap-4 justify-center">
            <a href="/" class="bg-darkPlum text-white px-10 py-4 uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-roseWood transition-all duration-500">Ke Beranda</a>
            <a href="/katalog" class="border border-darkPlum/20 px-10 py-4 uppercase tracking-[0.2em] text-[11px] font-medium hover:bg-darkPlum hover:text-white transition-all duration-500">Belanja Lagi</a>
        </div>
    </div>

</body>
</html>