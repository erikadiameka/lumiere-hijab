<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Katalog - Lumière</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@0.321.0/font/lucide.min.css">
    <script>
        tailwind.config = {
            theme: { extend: { colors: { blushBase: '#FCF9F9', dustyPink: '#F2E8E9', softMauve: '#E8DFE0', darkPlum: '#4A3C3D', roseWood: '#B89C9D' }, fontFamily: { serif: ['"Playfair Display"', 'serif'], sans: ['"Poppins"', 'sans-serif'] } } }
        }
    </script>
    <style>[x-cloak]{display:none!important} .glass-nav{background:rgba(252,249,249,0.85);backdrop-filter:blur(12px)}</style>
</head>
<body x-data="{ mobileMenu: false }" class="font-sans bg-blushBase text-darkPlum antialiased">

    <!-- NAVBAR -->
    <nav class="fixed w-full z-[60] glass-nav border-b border-roseWood/10">
        <div class="max-w-7xl mx-auto px-6 lg:px-12">
            <div class="flex justify-between items-center h-20">
                <button @click="mobileMenu = !mobileMenu" class="text-darkPlum lg:hidden"><i class="lucide-menu"></i></button>
                <a href="/" class="font-serif text-2xl font-semibold tracking-tighter text-darkPlum">LUMIÈRE</a>
                <div class="hidden lg:flex space-x-10">
                    <a href="/katalog" class="text-[11px] uppercase tracking-[0.2em] font-medium text-roseWood">Shop All</a>
                    <a href="/katalog?kategori=Pashmina" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">New Arrivals</a>
                    <a href="/tentang" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">Our Story</a>
                    <a href="/kontak" class="text-[11px] uppercase tracking-[0.2em] font-medium hover:text-roseWood transition">Kontak</a>
                </div>
                <a href="/keranjang" class="hover:text-roseWood transition"><i class="lucide-shopping-bag w-5 h-5"></i></a>
            </div>
        </div>
    </nav>

    <!-- MOBILE MENU -->
    <div x-show="mobileMenu" x-cloak class="fixed inset-0 z-[100]">
        <div class="absolute inset-0 bg-darkPlum/40 backdrop-blur-sm" @click="mobileMenu = false"></div>
        <div class="absolute inset-y-0 left-0 max-w-xs w-full bg-blushBase p-8 shadow-2xl">
            <div class="flex justify-between items-center mb-12">
                <h2 class="font-serif text-xl">Menu</h2>
                <button @click="mobileMenu = false"><i class="lucide-x"></i></button>
            </div>
            <div class="flex flex-col space-y-6">
                <a href="/katalog" class="text-lg font-light border-b border-softMauve pb-2">Katalog Produk</a>
                <a href="/tentang" class="text-lg font-light border-b border-softMauve pb-2">Tentang Kami</a>
                <a href="/kontak" class="text-lg font-light border-b border-softMauve pb-2">Kontak</a>
                <a href="/keranjang" class="text-lg font-light border-b border-softMauve pb-2">🛒 Keranjang</a>
            </div>
        </div>
    </div>

    <!-- HEADER -->
    <div class="pt-20 bg-dustyPink/30">
        <div class="max-w-7xl mx-auto px-6 py-16 text-center">
            <span class="text-[10px] uppercase tracking-[0.4em] text-roseWood font-semibold">Koleksi Kami</span>
            <h1 class="font-serif text-5xl text-darkPlum mt-3">Katalog Produk</h1>
        </div>
    </div>

    <!-- FILTER -->
    <div class="max-w-7xl mx-auto px-6 py-8">
        <form method="GET" action="/katalog" class="flex flex-wrap gap-3 items-center">
            <input type="text" name="cari" value="<%= cari %>" placeholder="Cari produk..."
                class="flex-1 min-w-[200px] border border-softMauve rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:border-roseWood transition">
            <select name="kategori" class="border border-softMauve rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:border-roseWood transition">
                <option value="">Semua Kategori</option>
                <% ['Segiempat','Pashmina','Instan','Bergo','Lainnya'].forEach(k => { %>
                <option value="<%= k %>" <%= kategori === k ? 'selected' : '' %>><%= k %></option>
                <% }) %>
            </select>
            <button type="submit" class="bg-darkPlum text-white px-8 py-3 rounded-lg text-sm font-medium hover:bg-roseWood transition">Cari</button>
            <a href="/katalog" class="border border-darkPlum/20 px-8 py-3 rounded-lg text-sm font-medium hover:bg-darkPlum hover:text-white transition">Reset</a>
        </form>
    </div>

    <!-- PRODUK GRID -->
    <div class="max-w-7xl mx-auto px-6 pb-24">
        <% if (produk.length === 0) { %>
        <div class="text-center py-24">
            <p class="font-serif text-2xl text-gray-300 mb-4">Produk tidak ditemukan</p>
            <a href="/katalog" class="text-roseWood text-sm hover:underline">Lihat semua produk</a>
        </div>
        <% } %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
            <% produk.forEach(p => { %>
            <div class="group">
                <a href="/produk/<%= p._id %>">
                    <div class="relative aspect-[3/4] bg-dustyPink mb-5 overflow-hidden">
                        <% if (p.foto && p.foto[0]) { %>
                            <img src="<%= p.foto[0] %>" alt="<%= p.nama %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition duration-700">
                        <% } else { %>
                            <div class="absolute inset-0 flex items-center justify-center text-roseWood/40 font-serif text-xl italic"><%= p.nama %></div>
                        <% } %>
                        <% if (p.hargaDiskon > 0) { %>
                        <div class="absolute top-3 left-3 bg-roseWood text-white text-[9px] px-2 py-1 uppercase tracking-wider">Sale</div>
                        <% } %>
                        <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                            <a href="/produk/<%= p._id %>" class="block w-full bg-white text-darkPlum py-3 text-[10px] uppercase tracking-[0.2em] font-bold hover:bg-darkPlum hover:text-white transition shadow-lg text-center">
                                Lihat Detail
                            </a>
                        </div>
                    </div>
                </a>
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1"><%= p.kategori %></p>
                <h3 class="text-sm font-medium mb-2 group-hover:text-roseWood transition"><%= p.nama %></h3>
                <% if (p.hargaDiskon > 0) { %>
                    <p class="text-gray-400 line-through text-xs">Rp <%= p.harga.toLocaleString('id-ID') %></p>
                    <p class="text-roseWood font-medium text-sm">Rp <%= p.hargaDiskon.toLocaleString('id-ID') %></p>
                <% } else { %>
                    <p class="text-roseWood font-medium text-sm">Rp <%= p.harga.toLocaleString('id-ID') %></p>
                <% } %>
                <p class="text-xs text-gray-300 mt-1">Stok: <%= p.stok %></p>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-darkPlum text-blushBase pt-16 pb-8">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <h1 class="font-serif text-3xl mb-4 tracking-tighter">LUMIÈRE</h1>
            <p class="text-softMauve/60 text-sm mb-6">Membawa keanggunan dalam setiap helai kain.</p>
            <div class="flex justify-center gap-8 text-sm text-softMauve/70 mb-8">
                <a href="/katalog" class="hover:text-white transition">Katalog</a>
                <a href="/tentang" class="hover:text-white transition">Tentang</a>
                <a href="/kontak" class="hover:text-white transition">Kontak</a>
                <a href="/keranjang" class="hover:text-white transition">Keranjang</a>
            </div>
            <p class="text-[10px] uppercase tracking-widest text-softMauve/40">&copy; 2025 Lumière Hijab Indonesia</p>
        </div>
    </footer>

</body>
</html>